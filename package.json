{
  "name": "npm-info-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that provides npm package information for AI agents during TypeScript development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "npm-info-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
