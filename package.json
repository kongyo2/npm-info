{
  "name": "npm-info-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that provides npm package information for AI agents during TypeScript development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "npm-info-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "oxlint --silent",
    "lint:strict": "oxlint --deny-warnings",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc --noEmit && oxlint --silent && prettier --check .",
    "check:file": "oxlint"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
